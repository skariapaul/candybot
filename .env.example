# Hugging Face Hub (dataset push/pull, checkpoint pull)
HF_USER=
HF_TOKEN=

# Remote MI300X training host (see training/README.md)
REMOTE_HOST=
REMOTE_USER=
REMOTE_SSH_KEY=~/.ssh/id_ed25519
REMOTE_CANDYBOT_DIR=~/candybot

# Overrides (normally set by configs/candybot.yaml, env wins if set)
CANDYBOT_ROBOT_PORT=/dev/so101_follower
CANDYBOT_DASHBOARD_PORT=8080
CANDYBOT_AUDIO_PROFILE=laptop   # usb_headset | laptop
