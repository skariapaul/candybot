# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pip-tmp/

# Env / secrets
.env

# LeRobot / calibration / datasets / checkpoints
configs/candybot_follower.json
configs/*_leader.json
outputs/
datasets/
*.onnx

# Voice models (downloaded, not vendored)
models/

# Wake word training: huge downloaded datasets + isolated venv, regenerable.
# Trained models get copied to candybot/models/wakeword/ (exempted below,
# small + hard to regenerate quickly) -- trainer/export/ is just the
# intermediate/duplicate location, not the authoritative copy.
training/wakeword/trainer/.venv-wakeword/
training/wakeword/trainer/data/
training/wakeword/trainer/output/
training/wakeword/trainer/export/

# Negating a file pattern doesn't work if a parent dir is already excluded
# (git won't descend into an ignored directory to re-check it) -- models/
# above and *.onnx further up both exclude this path, so every ancestor
# directory needs its own negation too, not just the final file pattern.
!candybot/models/
!candybot/models/wakeword/
!candybot/models/wakeword/*.onnx*

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp

# Logs
*.log
